{
  "expo": {
    "name": "Aero Test Manager",
    "slug": "aero-test-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1414B4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1414B4"
      },
      "package": "com.aerosimple.testmanager",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow Aero Test Manager to use the microphone for voice input",
          "speechRecognitionPermission": "Allow Aero Test Manager to use speech recognition for voice-to-text"
        }
      ]
    ],
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "811b142c-3c97-4120-9ec0-21ccac75b7b5"
      }
    },
    "owner": "jksprasad"
  }
}
